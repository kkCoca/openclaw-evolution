#!/bin/bash
# Git pre-commit Hook - 规范检查

echo "========================================"
echo "  Git 提交前规范检查"
echo "========================================"
echo ""

NORMS_CHECKS="$HOME/.openclaw/workspace/NORMS/checks"
EXIT_CODE=0

# L2: 生产区纯净检查
echo "【L2】生产区纯净检查:"
if "$NORMS_CHECKS/check-norm-02.sh" > /dev/null 2>&1; then
  echo "  ✅ 通过"
else
  echo "  ❌ 未通过 - 生产区包含违规文件"
  EXIT_CODE=1
fi

# L3: 命名归一化检查 (仅检查新增/修改的任务文件)
echo ""
echo "【L3】命名归一化检查:"
FILES=$(git diff --cached --name-only)
NAMING_VIOLATION=0

for file in $FILES; do
  # 检查任务目录命名
  if echo "$file" | grep -qE "^tasks/[0-9]+-"; then
    TASK_NAME=$(echo "$file" | cut -d'/' -f2)
    
    # 检查日期格式 (YYYYMMDD)
    DATE_PREFIX=$(echo "$TASK_NAME" | cut -d'-' -f1)
    if ! [[ $DATE_PREFIX =~ ^[0-9]{8}$ ]]; then
      echo "  ❌ 日期格式错误：$TASK_NAME (应为 YYYYMMDD)"
      NAMING_VIOLATION=1
    fi
    
    # 检查模块名格式 (小写 + 连字符)
    MODULE_NAME=$(echo "$TASK_NAME" | sed 's/^[0-9]*-//')
    if ! [[ $MODULE_NAME =~ ^[a-z0-9]+(-[a-z0-9]+)*$ ]]; then
      echo "  ❌ 模块名格式错误：$TASK_NAME (应为小写 + 连字符)"
      NAMING_VIOLATION=1
    fi
  fi
done

if [ $NAMING_VIOLATION -eq 0 ]; then
  echo "  ✅ 通过"
else
  EXIT_CODE=1
fi

# L4: 规划验证 (仅检查新增任务)
echo ""
echo "【L4】规划验证检查:"
NEW_TASKS=$(git diff --cached --name-only | grep -E "tasks/[0-9]+-" | cut -d'/' -f2 | sort -u)

for task in $NEW_TASKS; do
  TASK_DIR="/home/ouyp/Learning/Practice/openclaw-universe/tasks/$task"
  
  if [ -d "$TASK_DIR" ]; then
    MISSING=()
    
    # 检查 PRD.md
    if [ ! -f "$TASK_DIR/01_designing/PRD.md" ]; then
      MISSING+=("PRD.md")
    fi
    
    # 检查 ROADMAP.md
    if [ ! -f "$TASK_DIR/02_roadmapping/ROADMAP.md" ]; then
      MISSING+=("ROADMAP.md")
    fi
    
    # 检查 CONTEXT_PREFIX.md
    if [ ! -f "$TASK_DIR/03_detailing/CONTEXT_PREFIX.md" ]; then
      MISSING+=("CONTEXT_PREFIX.md")
    fi
    
    if [ ${#MISSING[@]} -gt 0 ]; then
      echo "  ❌ $task: 缺少 ${MISSING[*]}"
      EXIT_CODE=1
    else
      echo "  ✅ $task: 规划完整"
    fi
  fi
done

if [ -z "$NEW_TASKS" ]; then
  echo "  ℹ️  无新增任务，跳过"
fi

# 汇总
echo ""
echo "========================================"
if [ $EXIT_CODE -eq 0 ]; then
  echo "  ✅ 规范检查通过，允许提交"
  echo "========================================"
  exit 0
else
  echo "  ❌ 规范检查未通过，禁止提交"
  echo "========================================"
  echo ""
  echo "请修复上述违规后重新提交，或联系主人确认。"
  exit 1
fi
