#!/bin/bash
# Git post-commit Hook - 上游变更通知

TASK_DIR="$(pwd)"
TASK_NAME=$(basename "$TASK_DIR")
TIMESTAMP=$(date +%Y-%m-%d\ %H:%M:%S)
GIT_COMMIT=$(git rev-parse --short HEAD)

# 获取变更文件列表
CHANGED_FILES=$(git diff --name-only HEAD~1 HEAD)

# 检查是否包含关键文件变更
if echo "$CHANGED_FILES" | grep -qE "(MANIFEST\.json|package\.json|dist/|NORMS/)"; then
  # 记录变更通知
  NOTIFICATION_LOG="$HOME/.openclaw/workspace/research/notifications/upstream-changes.log"
  
  # 确保目录存在
  mkdir -p "$(dirname "$NOTIFICATION_LOG")"
  
  echo "$TIMESTAMP $TASK_NAME ($GIT_COMMIT) 已更新 - 变更：$CHANGED_FILES" >> "$NOTIFICATION_LOG"
  
  echo "📢 上游变更已记录：$TASK_NAME"
  
  # 识别下游依赖 Task
  MODULE_NAME=$(echo $TASK_NAME | sed 's/^[0-9]*-//')
  
  for task_dir in /home/ouyp/Learning/Practice/openclaw-universe/tasks/*/; do
    MANIFEST="$task_dir/04_coding/MANIFEST.json"
    if [ -f "$MANIFEST" ]; then
      # 检查是否依赖当前 Task
      if grep -q "\"module\": \".*$MODULE_NAME\"" "$MANIFEST" 2>/dev/null || \
         grep -q "\"task\": \".*$TASK_NAME\"" "$MANIFEST" 2>/dev/null; then
        DOWNSTREAM_NAME=$(basename "$task_dir")
        echo "$TIMESTAMP ⚠️  下游 Task [$DOWNSTREAM_NAME] 依赖的 [$TASK_NAME] 已更新，建议回归测试" >> "$NOTIFICATION_LOG"
      fi
    fi
  done
fi
