{
  "name": "ddg-websearch",
  "version": "1.0.0",
  "description": "OpenClaw web search extension with DuckDuckGo primary and Bing fallback",
  "main": "src/index.js",
  "scripts": {
    "test": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js tests/parser-integration.test.js",
    "test:e2e": "node --test tests/e2e/*.test.js",
    "test:all": "npm run test && npm run test:integration",
    "build": "node -e \"require('./src/index.js')\"",
    "deploy": "npm run test:all && node scripts/deploy.js",
    "verify": "node test-verify.js",
    "fetch-fixtures": "node scripts/fetch-fixtures.js"
  },
  "license": "MIT"
}
