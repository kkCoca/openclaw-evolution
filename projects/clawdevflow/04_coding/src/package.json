{
  "name": "clawdevflow",
  "version": "3.3.0",
  "description": "ClawDevFlow (CDF) - AI 辅助研发流程编排引擎",
  "main": "workflow-executor.js",
  "bin": {
    "clawdevflow": "./workflow-executor.js"
  },
  "scripts": {
    "test": "node ../../tests/run-all-tests.js",
    "lint:docs": "node scripts/lint-docs.js",
    "test:state": "node ../../tests/test-state-manager.js",
    "test:adapter": "node ../../tests/test-ai-tool-adapter.js",
    "test:env": "node ../../tests/test-substitute-env.js",
    "test:workflow": "node ../../tests/test-cdf-workflow.js",
    "test:integration": "node ../../tests/test-cdf-integration.js",
    "test:review": "node ../../tests/test-review-agents.js && node ../../tests/test-review-code.js && node ../../tests/test-review-orchestrator.js",
    "test:coverage": "nyc --reporter=html --reporter=text node ../../tests/run-all-tests.js",
    "report:coverage": "nyc report --reporter=html",
    "install:skill": "./install.sh"
  },
  "keywords": [
    "openclaw",
    "skill",
    "workflow",
    "ai",
    "research",
    "development",
    "clawdevflow"
  ],
  "author": "openclaw-ouyp",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/cola16/openclaw-evolution.git"
  },
  "devDependencies": {
    "nyc": "^15.1.0"
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "nyc": {
    "include": [
      "cdf-orchestrator/**/*.js",
      "adapters/**/*.js",
      "review-*/**/*.js",
      "ai-tool-adapter.js"
    ],
    "exclude": [
      "tests/**",
      "bundled-skills/**",
      "node_modules/**"
    ],
    "check-coverage": false,
    "lines": 80,
    "functions": 80,
    "branches": 80,
    "statements": 80,
    "reporter": [
      "html",
      "text"
    ],
    "cache": true,
    "all": true
  }
}
