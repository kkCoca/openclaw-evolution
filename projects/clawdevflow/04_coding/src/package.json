{
  "name": "clawdevflow",
  "version": "3.1.0",
  "description": "ClawDevFlow (CDF) - AI 辅助研发流程编排引擎",
  "main": "workflow-executor.js",
  "bin": {
    "clawdevflow": "./workflow-executor.js"
  },
  "scripts": {
    "test": "node ../tests/run-all-tests.js",
    "test:state": "node ../tests/test-state-manager.js",
    "test:adapter": "node ../tests/test-ai-tool-adapter.js",
    "test:workflow": "node ../tests/test-cdf-workflow.js",
    "test:integration": "node ../tests/test-cdf-integration.js",
    "test:review": "node ../tests/test-review-agents.js && node ../tests/test-review-code.js && node ../tests/test-review-orchestrator.js",
    "install:skill": "./install.sh"
  },
  "keywords": [
    "openclaw",
    "skill",
    "workflow",
    "ai",
    "research",
    "development",
    "clawdevflow"
  ],
  "author": "openclaw-ouyp",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/cola16/openclaw-evolution.git"
  },
  "devDependencies": {
    "nyc": "^15.1.0"
  }
}
