#!/bin/bash
# post-commit - 提交后 Hook v1.0.1
# 提交后自动同步到镜像仓库，支持 OpenClaw 环境

# 获取 Hook 所在目录（可能是 .git/hooks 或 .multi-git/hooks）
HOOK_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 智能查找真正的 hooks 目录
# 如果是软链接，找到真实位置
if [ -L "$HOOK_SCRIPT_DIR/post-commit" ] || [[ "$HOOK_SCRIPT_DIR" == *".git/hooks"* ]]; then
    # 在 .git/hooks 中，真实 hooks 在 .multi-git/hooks
    GIT_DIR="$(cd "$HOOK_SCRIPT_DIR/.." && pwd)"
    REPO_ROOT="$(cd "$GIT_DIR/.." && pwd)"
    SCRIPT_DIR="$REPO_ROOT/.multi-git/hooks"
else
    # 直接在 .multi-git/hooks 中
    SCRIPT_DIR="$HOOK_SCRIPT_DIR"
fi

# 验证目录存在
if [ ! -d "$SCRIPT_DIR" ]; then
    echo "[multi-git] [ERROR] 找不到 hooks 目录：$SCRIPT_DIR" >&2
    exit 0
fi

# 直接加载配置模块（含 OpenClaw 环境检测）
source "$SCRIPT_DIR/config.sh"

# 直接加载日志模块
source "$SCRIPT_DIR/logger.sh"

# 加载配置
if ! load_config; then
    log_error "无法加载配置文件，请检查 .multi-git/config.json"
    exit 0  # 不阻塞提交流程
fi

# 初始化日志级别
LOG_LEVEL=$(get_log_level)
init_logger "$LOG_LEVEL"

log_debug "post-commit Hook 触发"
log_debug "脚本目录：$SCRIPT_DIR"

# 检测 OpenClaw 环境
if is_openclaw_env; then
    log_debug "检测到 OpenClaw 环境"
fi

# 检查同步模式
SYNC_MODE=$(get_sync_mode)
if [ "$SYNC_MODE" = "manual" ]; then
    log_debug "手动同步模式，跳过自动同步"
    exit 0
fi

# 获取当前分支
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ -z "$CURRENT_BRANCH" ]; then
    log_debug "不在分支上，跳过同步"
    exit 0
fi

log_debug "当前分支：$CURRENT_BRANCH"

# 加载同步模块并执行
source "$SCRIPT_DIR/sync.sh"
sync_all_mirrors

# 不阻塞提交流程，始终返回 0
exit 0
