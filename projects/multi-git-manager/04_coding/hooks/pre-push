#!/bin/bash
# pre-push - 推送前 Hook
# 推送前验证配置

# 获取脚本所在目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 加载日志模块
source "$SCRIPT_DIR/logger.sh"

# 加载配置模块
source "$SCRIPT_DIR/config.sh"

# 加载配置
if ! load_config; then
    log_error "配置文件不存在，请运行 install.sh 初始化"
    exit 1
fi

# 初始化日志级别
LOG_LEVEL=$(get_log_level)
init_logger "$LOG_LEVEL"

log_debug "pre-push Hook 触发"

# 验证主仓库配置
PRIMARY=$(get_primary)
if [ -z "$PRIMARY" ]; then
    log_error "未配置主仓库 (primary)"
    exit 1
fi

log_debug "主仓库：$PRIMARY"
log_debug "配置验证通过"

exit 0
